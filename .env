# .env — configuracao dos workers (opcional)
# Os workers usam estas variaveis se definidas, caso contrario usam os defaults

# Portas dos workers
QWEN_PORT=5001
INDEXTTS_PORT=5002

# URLs que o engine.py usa para chamar os workers
QWEN_WORKER_URL=http://127.0.0.1:5001
INDEXTTS_WORKER_URL=http://127.0.0.1:5002

# Modelo do Qwen (pode trocar por versao clone/base)
QWEN_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice

# Pasta dos modelos IndexTTS
INDEXTTS_MODEL_DIR=checkpoints
INDEXTTS_CFG=checkpoints/config.yaml
